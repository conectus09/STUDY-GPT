# LiveKit (required for video/voice/text)
#
# LOCAL DEV — run `npm run livekit` in a second terminal, then use:
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
#
# PRODUCTION — get keys from https://cloud.livekit.io
# LIVEKIT_API_KEY=your_api_key
# LIVEKIT_API_SECRET=your_api_secret
# NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Redis (optional in dev — without it, 2 users match on the same PC/server)
# REDIS_URL=redis://localhost:6379